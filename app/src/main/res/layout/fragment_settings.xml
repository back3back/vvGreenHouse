<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="系统设置"
            android:textColor="@color/primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- ====== 硬件连接模式 ====== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🔌 硬件连接模式" android:textColor="@color/primary"
                    android:textSize="15sp" android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rg_hw_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">

                    <RadioButton android:id="@+id/rb_mock"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="模拟模式（开发演示用）" android:textSize="14sp" />
                    <RadioButton android:id="@+id/rb_real"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="真实模式（TCP Socket）" android:textSize="14sp" />
                    <RadioButton android:id="@+id/rb_fro"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Fro工具包（备选）" android:textSize="14sp" />
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ====== 服务器配置 ====== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_server"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical"
                android:padding="14dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🌐 服务器连接配置" android:textColor="@color/primary"
                    android:textSize="15sp" android:textStyle="bold" />

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="horizontal"
                    android:layout_marginTop="10dp" android:gravity="center_vertical">
                    <TextView android:layout_width="40dp" android:layout_height="wrap_content"
                        android:text="IP:" android:textSize="14sp" />
                    <EditText android:id="@+id/et_server_ip"
                        android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                        android:text="192.168.1.100" android:textSize="14sp" android:singleLine="true"
                        android:background="@drawable/spinner_bg" android:paddingStart="8dp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="horizontal"
                    android:layout_marginTop="8dp" android:gravity="center_vertical">
                    <TextView android:layout_width="40dp" android:layout_height="wrap_content"
                        android:text="端口:" android:textSize="14sp" />
                    <EditText android:id="@+id/et_server_port"
                        android:layout_width="120dp" android:layout_height="40dp"
                        android:text="8080" android:textSize="14sp" android:singleLine="true"
                        android:inputType="number"
                        android:background="@drawable/spinner_bg" android:paddingStart="8dp" />
                </LinearLayout>

                <Button android:id="@+id/btn_save_server"
                    android:layout_width="wrap_content" android:layout_height="38dp"
                    android:layout_marginTop="10dp" android:text="保存配置"
                    android:textSize="13sp" android:backgroundTint="@color/primary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ====== 大棚信息 ====== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical"
                android:padding="14dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🏠 大棚信息管理" android:textColor="@color/primary"
                    android:textSize="15sp" android:textStyle="bold" />

                <LinearLayout android:id="@+id/layout_gh_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ====== 数据管理 ====== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical"
                android:padding="14dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="💾 数据管理" android:textColor="@color/primary"
                    android:textSize="15sp" android:textStyle="bold" />

                <Button android:id="@+id/btn_backup_db"
                    android:layout_width="match_parent" android:layout_height="42dp"
                    android:layout_marginTop="10dp" android:text="数据库备份到本地"
                    android:textSize="14sp" android:backgroundTint="@color/primary" />

                <Button android:id="@+id/btn_restore_db"
                    android:layout_width="match_parent" android:layout_height="42dp"
                    android:layout_marginTop="8dp" android:text="从备份文件恢复"
                    android:textSize="14sp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ====== 关于 ====== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical"
                android:padding="14dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ℹ 关于" android:textColor="@color/primary"
                    android:textSize="15sp" android:textStyle="bold" />

                <TextView android:id="@+id/tv_about"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="智能花卉大棚种植系统 v1.0"
                    android:textSize="13sp" android:textColor="@color/text_secondary"
                    android:layout_marginTop="8dp" android:lineSpacingExtra="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
