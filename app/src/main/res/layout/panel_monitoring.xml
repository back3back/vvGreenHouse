<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- URL 输入栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:background="@color/white"
        android:elevation="1dp">

        <EditText
            android:id="@+id/et_video_url"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:hint="输入视频流地址 (RTSP/HLS/HTTP)"
            android:textSize="13sp"
            android:paddingStart="8dp"
            android:singleLine="true"
            android:background="@drawable/spinner_bg" />

        <Button
            android:id="@+id/btn_load_video"
            android:layout_width="60dp"
            android:layout_height="40dp"
            android:text="加载"
            android:textSize="13sp"
            android:layout_marginStart="6dp"
            android:backgroundTint="@color/primary" />
    </LinearLayout>

    <!-- WebView 监控区 -->
    <WebView
        android:id="@+id/webview_monitor"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- 状态提示 -->
    <TextView
        android:id="@+id/tv_video_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📷 输入视频流URL后点击【加载】即可预览\n支持 HTTP 图片流 / HLS(.m3u8) / RTSP"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:gravity="center"
        android:padding="20dp" />
</LinearLayout>
