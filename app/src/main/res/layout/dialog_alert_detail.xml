<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- 传感器类型图标 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_detail_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌡"
            android:textSize="36sp"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_detail_sensor_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="空气温度"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_detail_level"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="中度预警"
                android:textColor="@color/warning_orange"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- 详情表 -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="6dp">
                <TextView android:layout_width="70dp" android:layout_height="wrap_content"
                    android:text="大棚ID" android:textColor="@color/text_secondary" android:textSize="13sp" />
                <TextView android:id="@+id/tv_detail_gh" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="GH-001"
                    android:textColor="@color/text_primary" android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="6dp">
                <TextView android:layout_width="70dp" android:layout_height="wrap_content"
                    android:text="实测值" android:textColor="@color/text_secondary" android:textSize="13sp" />
                <TextView android:id="@+id/tv_detail_value" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="32.5°C"
                    android:textColor="@color/error_red" android:textSize="13sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="6dp">
                <TextView android:layout_width="70dp" android:layout_height="wrap_content"
                    android:text="阈值范围" android:textColor="@color/text_secondary" android:textSize="13sp" />
                <TextView android:id="@+id/tv_detail_range" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="18.0 ~ 30.0 °C"
                    android:textColor="@color/text_primary" android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="6dp">
                <TextView android:layout_width="70dp" android:layout_height="wrap_content"
                    android:text="偏离方向" android:textColor="@color/text_secondary" android:textSize="13sp" />
                <TextView android:id="@+id/tv_detail_direction" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="偏高↑"
                    android:textColor="@color/error_red" android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="6dp">
                <TextView android:layout_width="70dp" android:layout_height="wrap_content"
                    android:text="预警时间" android:textColor="@color/text_secondary" android:textSize="13sp" />
                <TextView android:id="@+id/tv_detail_time" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="2026-06-20 10:30:00"
                    android:textColor="@color/text_primary" android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
