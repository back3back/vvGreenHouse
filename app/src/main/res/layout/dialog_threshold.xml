<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="预警阈值设置"
        android:textColor="@color/primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="400dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 空气温度 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                    android:text="🌡 温度" android:textSize="14sp" />
                <EditText android:id="@+id/et_temp_min" android:layout_width="0dp"
                    android:layout_height="40dp" android:layout_weight="1"
                    android:inputType="numberDecimal" android:gravity="center"
                    android:background="@drawable/spinner_bg" android:hint="下限" />
                <TextView android:layout_width="20dp" android:layout_height="wrap_content"
                    android:text="~" android:gravity="center" />
                <EditText android:id="@+id/et_temp_max" android:layout_width="0dp"
                    android:layout_height="40dp" android:layout_weight="1"
                    android:inputType="numberDecimal" android:gravity="center"
                    android:background="@drawable/spinner_bg" android:hint="上限" />
                <TextView android:layout_width="30dp" android:layout_height="wrap_content"
                    android:text="°C" android:textSize="12sp" android:gravity="center" />
            </LinearLayout>

            <!-- 空气湿度 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                    android:text="💧 湿度" android:textSize="14sp" />
                <EditText android:id="@+id/et_humidity_min" android:layout_width="0dp"
                    android:layout_height="40dp" android:layout_weight="1"
                    android:inputType="numberDecimal" android:gravity="center"
                    android:background="@drawable/spinner_bg" android:hint="下限" />
                <TextView android:layout_width="20dp" android:layout_height="wrap_content"
                    android:text="~" android:gravity="center" />
                <EditText android:id="@+id/et_humidity_max" android:layout_width="0dp"
                    android:layout_height="40dp" android:layout_weight="1"
                    android:inputType="numberDecimal" android:gravity="center"
                    android:background="@drawable/spinner_bg" android:hint="上限" />
                <TextView android:layout_width="30dp" android:layout_height="wrap_content"
                    android:text="%" android:textSize="12sp" android:gravity="center" />
            </LinearLayout>

            <!-- CO₂ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                    android:text="🫧 CO₂" android:textSize="14sp" />
                <EditText android:id="@+id/et_co2_min" android:layout_width="0dp"
                    android:layout_height="40dp" android:layout_weight="1"
                    android:inputType="numberDecimal" android:gravity="center"
                    android:background="@drawable/spinner_bg" android:hint="下限" />
                <TextView android:layout_width="20dp" android:layout_height="wrap_content"
                    android:text="~" android:gravity="center" />
                <EditText android:id="@+id/et_co2_max" android:layout_width="0dp"
                    android:layout_height="40dp" android:layout_weight="1"
                    android:inputType="numberDecimal" android:gravity="center"
                    android:background="@drawable/spinner_bg" android:hint="上限" />
                <TextView android:layout_width="30dp" android:layout_height="wrap_content"
                    android:text="ppm" android:textSize="12sp" android:gravity="center" />
            </LinearLayout>

            <!-- 光照 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                    android:text="☀ 光照" android:textSize="14sp" />
                <EditText android:id="@+id/et_light_min" android:layout_width="0dp"
                    android:layout_height="40dp" android:layout_weight="1"
                    android:inputType="numberDecimal" android:gravity="center"
                    android:background="@drawable/spinner_bg" android:hint="下限" />
                <TextView android:layout_width="20dp" android:layout_height="wrap_content"
                    android:text="~" android:gravity="center" />
                <EditText android:id="@+id/et_light_max" android:layout_width="0dp"
                    android:layout_height="40dp" android:layout_weight="1"
                    android:inputType="numberDecimal" android:gravity="center"
                    android:background="@drawable/spinner_bg" android:hint="上限" />
                <TextView android:layout_width="30dp" android:layout_height="wrap_content"
                    android:text="lux" android:textSize="12sp" android:gravity="center" />
            </LinearLayout>

            <!-- 土壤温度 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                    android:text="🌱 土温" android:textSize="14sp" />
                <EditText android:id="@+id/et_soil_temp_min" android:layout_width="0dp"
                    android:layout_height="40dp" android:layout_weight="1"
                    android:inputType="numberDecimal" android:gravity="center"
                    android:background="@drawable/spinner_bg" android:hint="下限" />
                <TextView android:layout_width="20dp" android:layout_height="wrap_content"
                    android:text="~" android:gravity="center" />
                <EditText android:id="@+id/et_soil_temp_max" android:layout_width="0dp"
                    android:layout_height="40dp" android:layout_weight="1"
                    android:inputType="numberDecimal" android:gravity="center"
                    android:background="@drawable/spinner_bg" android:hint="上限" />
                <TextView android:layout_width="30dp" android:layout_height="wrap_content"
                    android:text="°C" android:textSize="12sp" android:gravity="center" />
            </LinearLayout>

            <!-- 土壤湿度 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                    android:text="💦 土湿" android:textSize="14sp" />
                <EditText android:id="@+id/et_soil_humidity_min" android:layout_width="0dp"
                    android:layout_height="40dp" android:layout_weight="1"
                    android:inputType="numberDecimal" android:gravity="center"
                    android:background="@drawable/spinner_bg" android:hint="下限" />
                <TextView android:layout_width="20dp" android:layout_height="wrap_content"
                    android:text="~" android:gravity="center" />
                <EditText android:id="@+id/et_soil_humidity_max" android:layout_width="0dp"
                    android:layout_height="40dp" android:layout_weight="1"
                    android:inputType="numberDecimal" android:gravity="center"
                    android:background="@drawable/spinner_bg" android:hint="上限" />
                <TextView android:layout_width="30dp" android:layout_height="wrap_content"
                    android:text="%" android:textSize="12sp" android:gravity="center" />
            </LinearLayout>

            <!-- pH -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                    android:text="⚗ pH" android:textSize="14sp" />
                <EditText android:id="@+id/et_ph_min" android:layout_width="0dp"
                    android:layout_height="40dp" android:layout_weight="1"
                    android:inputType="numberDecimal" android:gravity="center"
                    android:background="@drawable/spinner_bg" android:hint="下限" />
                <TextView android:layout_width="20dp" android:layout_height="wrap_content"
                    android:text="~" android:gravity="center" />
                <EditText android:id="@+id/et_ph_max" android:layout_width="0dp"
                    android:layout_height="40dp" android:layout_weight="1"
                    android:inputType="numberDecimal" android:gravity="center"
                    android:background="@drawable/spinner_bg" android:hint="上限" />
                <TextView android:layout_width="30dp" android:layout_height="wrap_content"
                    android:text="" android:textSize="12sp" android:gravity="center" />
            </LinearLayout>

            <!-- EC -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                    android:text="⚡ EC" android:textSize="14sp" />
                <EditText android:id="@+id/et_ec_min" android:layout_width="0dp"
                    android:layout_height="40dp" android:layout_weight="1"
                    android:inputType="numberDecimal" android:gravity="center"
                    android:background="@drawable/spinner_bg" android:hint="下限" />
                <TextView android:layout_width="20dp" android:layout_height="wrap_content"
                    android:text="~" android:gravity="center" />
                <EditText android:id="@+id/et_ec_max" android:layout_width="0dp"
                    android:layout_height="40dp" android:layout_weight="1"
                    android:inputType="numberDecimal" android:gravity="center"
                    android:background="@drawable/spinner_bg" android:hint="上限" />
                <TextView android:layout_width="30dp" android:layout_height="wrap_content"
                    android:text="mS" android:textSize="12sp" android:gravity="center" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_reset_defaults"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="恢复默认" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_threshold"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="保存"
            android:backgroundTint="@color/primary"
            android:textColor="@color/white"
            app:cornerRadius="8dp" />
    </LinearLayout>
</LinearLayout>
