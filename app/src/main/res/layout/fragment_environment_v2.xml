<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- 标题 -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="环境监测 — GH-001"
        android:textColor="@color/primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:paddingStart="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="4dp" />

    <!-- 大棚 TabLayout (可横向滚动) -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_greenhouse"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:background="@color/white"
        app:tabMode="scrollable"
        app:tabGravity="fill"
        app:tabSelectedTextColor="@color/primary"
        app:tabTextColor="@color/text_secondary"
        app:tabIndicatorColor="@color/primary"
        app:tabIndicatorHeight="3dp"
        app:tabTextAppearance="@android:style/TextAppearance.Widget.TabWidget"
        android:elevation="1dp" />

    <!-- ===== 实时监测面板 ===== -->
    <FrameLayout
        android:id="@+id/panel_monitor"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- 滚动区域：传感器卡片网格 -->
            <ScrollView
                android:id="@+id/scroll_cards"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="8dp"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 状态信息 -->
                    <TextView
                        android:id="@+id/tv_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="模拟数据每5秒自动刷新"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_marginStart="4dp"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/tv_last_update"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="上次更新: --"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:layout_marginStart="4dp"
                        android:layout_marginBottom="8dp" />

                    <!-- 传感器卡片网格 (2列，动态添加8张卡片) -->
                    <GridLayout
                        android:id="@+id/grid_cards"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="4"
                        android:useDefaultMargins="false">
                    </GridLayout>
                </LinearLayout>
            </ScrollView>

            <!-- 底部操作按钮栏 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="10dp"
                android:gravity="center"
                android:background="@color/white"
                android:elevation="4dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_refresh"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="立即刷新"
                    android:textSize="13sp"
                    android:backgroundTint="@color/primary"
                    android:textColor="@color/white"
                    app:cornerRadius="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_abnormal"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="异常模式 ▾"
                    android:textSize="13sp"
                    android:backgroundTint="@color/warning_orange"
                    android:textColor="@color/white"
                    app:cornerRadius="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_history"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="历史数据"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_threshold"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="阈值设置"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- ===== 历史查询面板 ===== -->
    <FrameLayout
        android:id="@+id/panel_history"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone" />
</LinearLayout>
